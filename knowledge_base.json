def clean_text(text):
    return re.findall(r"\w+", text.lower())

def normalize_words(words):
    mapped = []
    for w in words:
        if w in ["soybeans", "soybean"]:
            mapped.append("soybean")
        elif w in ["maizes", "maize"]:
            mapped.append("maize")
        elif w in ["nodulating", "nodulation", "nodule", "nodules"]:
            mapped.append("nodulation")
        elif w in ["fixing", "fix", "fixed"]:
            mapped.append("fixing")
        else:
            mapped.append(w)
    return mapped

def score_match(user_question, item):
    user_words = normalize_words(clean_text(user_question))
    item_words = normalize_words(clean_text(item["question"] + " " + item["answer"]))
    user_set = set(user_words)
    item_set = set(item_words)

    score = 0
    overlap = user_set.intersection(item_set)
    score += len(overlap) * 3

    if "soybean" in user_set and "soybean" in item_set:
        score += 10
    if "maize" in user_set and "maize" in item_set:
        score += 10

    important_terms = [
        "nodulation", "fixing", "nitrogen", "inoculant", "yellow",
        "purple", "blight", "spots", "fertility", "fertilizer",
        "drought", "root", "rot", "weeds", "disease", "pest"
    ]

    for term in important_terms:
        if term in user_set and term in item_set:
            score += 5

    if "soybean" in user_question.lower() and "soybean" not in item["question"].lower():
        score -= 8
    if "maize" in user_question.lower() and "maize" not in item["question"].lower():
        score -= 8

    return score

def find_best_matches(user_question, top_n=3):
    scored = []
    for item in data:
        scored.append((score_match(user_question, item), item))
    scored.sort(key=lambda x: x[0], reverse=True)
    return [item for score, item in scored if score > 0][:top_n]

def build_context(matches):
    if not matches:
        return "No relevant farming knowledge found."
    return "\n\n".join(
        [f"Question: {item['question']}\nAnswer: {item['answer']}" for item in matches]
    )

def build_local_answer(user_question):
    matches = find_best_matches(user_question)
    if not matches:
        fallback = {
            "Likely issue": "Unclear from current knowledge base",
            "Why this may be happening": "The system could not find a strong maize or soybean match.",
            "What to check next": "Rephrase the question with the crop, visible symptoms, field condition, and growth stage.",
            "Suggested action": "Use a more specific question or expand the knowledge base.",
            "When to seek local support": "Seek local support if symptoms are spreading quickly or affecting a large area."
        }
        return fallback, []

    best = matches[0]["answer"]
    response = {
        "Likely issue": best,
        "Why this may be happening": "This answer was selected from the closest crop-specific knowledge in the system.",
        "What to check next": "Compare crop stage, leaf color, damage pattern, field moisture, and any pest or disease signs.",
        "Suggested action": "Use this answer as a first guide, then confirm with field observation.",
        "When to seek local support": "Seek local support for severe disease pressure, rapid spread, or unclear cases."
    }
    return response, matches

def build_ai_answer(user_question, matches):
    if not USE_OPENAI or client is None:
        return None

    context = build_context(matches)

    prompt = f"""
You are FarmerChat, an agricultural support assistant for maize and soybean farmers.

Use only the knowledge below.
Return your answer in this exact JSON format (no extra text):

{{
  "Likely issue": "...",
  "Why this may be happening": "...",
  "What to check next": "...",
  "Suggested action": "...",
  "When to seek local support": "..."
}}

Requirements:
- Keep the language simple, practical, and field-oriented.
- Do not make up facts.
- If the farmer asks about soybean, do not answer with maize advice.
- If the farmer asks about maize, do not answer with soybean advice.

Farmer question:
{user_question}

Knowledge:
{context}
"""

    try:
        response = client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt}],
            temperature=0.3,
            max_tokens=600
        )
        raw_text = response.choices[0].message.content.strip()
        
        # Try JSON first (more reliable)
        try:
            return json.loads(raw_text)
        except:
            # Fallback to old text parsing
            return parse_ai_answer(raw_text)
    except Exception:
        return None

def parse_ai_answer(text):
    sections = {
        "Likely issue": "",
        "Why this may be happening": "",
        "What to check next": "",
        "Suggested action": "",
        "When to seek local support": ""
    }

    current = None
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue

        found = False
        for key in sections:
            if line.startswith(key + ":") or line.startswith(key + " :"):
                sections[key] = line.split(":", 1)[1].strip()
                current = key
                found = True
                break

        if not found and current:
            sections[current] += " " + line

    return sections

def render_answer_card(sections):
    def safe(key):
        return escape(str(sections.get(key, "") or "Not available"))

    st.markdown(f"""
    <div class="answer-card">
        <div class="answer-block">
            <div class="answer-label">Likely issue</div>
            <div>{safe("Likely issue")}</div>
        </div>
        <div class="answer-block">
            <div class="answer-label">Why this may be happening</div>
            <div>{safe("Why this may be happening")}</div>
        </div>
        <div class="answer-block">
            <div class="answer-label">What to check next</div>
            <div>{safe("What to check next")}</div>
        </div>
        <div class="answer-block">
            <div class="answer-label">Suggested action</div>
            <div>{safe("Suggested action")}</div>
        </div>
        <div class="answer-block" style="margin-bottom:0;">
            <div class="answer-label">When to seek local support</div>
            <div>{safe("When to seek local support")}</div>
        </div>
    </div>
    """, unsafe_allow_html=True)

